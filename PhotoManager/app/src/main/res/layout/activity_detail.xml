<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FCE4EC">
    <ImageView android:id="@+id/detail_image" android:layout_width="match_parent" android:layout_height="300dp" />
    <TextView android:id="@+id/txt_details" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="#000000" android:padding="10dp" />
    <Button android:id="@+id/btn_delete" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Delete" android:backgroundTint="#D32F2F" />
</LinearLayout>